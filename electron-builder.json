{
  "appId": "com.photographycoach.v2",
  "productName": "Photography Coach",
  "copyright": "Copyright © 2026",
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json",
    "!node_modules/sharp/**/*",
    "!node_modules/exiftool-vendored/**/*",
    "!node_modules/@img/**/*"
  ],
  "extraMetadata": {
    "main": "electron-dist/main.js"
  },
  "mac": {
    "category": "public.app-category.photography",
    "icon": "build/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      },
      {
        "target": "zip",
        "arch": ["arm64"]
      }
    ]
  },
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "linux": {
    "icon": "build/icon.png",
    "category": "Graphics",
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
